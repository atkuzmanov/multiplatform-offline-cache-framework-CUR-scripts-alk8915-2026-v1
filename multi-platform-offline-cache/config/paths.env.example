# Copy to paths.env and set FRAMEWORKS_ROOT to the directory that contains
# ubuntu-rebuild-framework, macos-rebuild-framework, and windows-rebuild-framework.
# If multi-platform-offline-cache sits next to those three folders, leave empty
# and the scripts will use the parent of multi-platform-offline-cache by default.
# Or set an absolute path, e.g.:
# FRAMEWORKS_ROOT=/path/to/ubuntu-rebuild-framework-CURSOR-scripts-alk8915-2026-v1

FRAMEWORKS_ROOT=""
